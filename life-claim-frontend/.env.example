# Copy to .env — Vite loads VITE_* and REACT_APP_* (see vite.config.js envPrefix).
# Section K: browser calls /api only; Alfresco/WhatsApp/DB are backend-side (docs/INTEGRATIONS.md).

VITE_ENVIRONMENT=SIT
REACT_APP_ENVIRONMENT=SIT

VITE_PROXY_TARGET=https://192.168.60.62:3010
REACT_APP_PROXY_TARGET=https://192.168.60.62:3010

VITE_API_URL=
REACT_APP_API_URL=

VITE_KEYCLOAK_URL=http://localhost:8081
REACT_APP_KEYCLOAK_URL=http://localhost:8081

VITE_IDLE_TIMEOUT_MINUTES=5
REACT_APP_IDLE_TIMEOUT_MINUTES=5

# Site key from Google Admin (public in browser by design; NOT backend RECAPTCHA_SECRET_KEY)
VITE_RECAPTCHA_SITE_KEY=your_site_key_here
REACT_APP_RECAPTCHA_SITE_KEY=your_site_key_here

# Optional: RSA public key for login password encryption (auto-read from backend keys/login_public.pem at build)
# VITE_LOGIN_RSA_PUBLIC_KEY=

# SIT / dev when Google is blocked
VITE_CAPTCHA_OPTIONAL=true
REACT_APP_CAPTCHA_OPTIONAL=true

VITE_SESSION_CHECK_INTERVAL_MS=90000
REACT_APP_SESSION_CHECK_INTERVAL_MS=90000
