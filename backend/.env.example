# Copy this to .env and fill in your values
PORT=3009
HOST=0.0.0.0
USE_HTTPS=false
NODE_ENV=development

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=claims_poc
DB_PORT=3306

JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=8h
SESSION_SECRET=your-session-secret

KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=life-claims
KEYCLOAK_CLIENT_ID=life-claims-frontend

SESSION_IDLE_TIMEOUT_MINUTES=5
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000

TXN_API_BASE_URL=http://localhost:3003
DOCUMENT_VIEWER_IP=192.168.60.63:8080
DEV_DOCUMENT_STORAGE_LOCATION=your-alfresco-folder-uuid
alfresco_API_URL=http://192.168.60.63:8080/alfresco/api/-default-/public/alfresco/versions/1/nodes/
DMS_USER_ID=admin
DMS_PASSWORD=admin

EMAIL_ENABLED=false
RECAPTCHA_BYPASS=true
NOTIFICATION_USE_QUEUE=false

CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000
ENVIRONMENT=SIT
EXPOSE_ERROR_DETAIL=true
