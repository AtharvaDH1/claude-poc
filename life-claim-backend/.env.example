# Copy to .env — v2 backend (PORT 3010; v1 legacy uses 3008).

NODE_ENV=development
ENVIRONMENT=SIT

PORT=3010
HOST=0.0.0.0
USE_HTTPS=true
SERVER_IP=192.168.60.62

KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=life-claims
KEYCLOAK_CLIENT_ID=life-claims-frontend
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REQUEST_TIMEOUT_MS=20000

SINGLE_SESSION_ENFORCED=false

SESSION_SECRET=change-this-session-secret-dev-only
SESSION_IDLE_TIMEOUT_MINUTES=5
AUDIT_SESSION_TTL_MINUTES=5

KEYCLOAK_LOCKOUT_ENABLED=true
KEYCLOAK_LOCKOUT_MAX_ATTEMPTS=5
KEYCLOAK_LOCKOUT_DURATION_MS=900000
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000
RATE_LIMIT_AUTH_MAX=50

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_DATABASE=claims_poc

RECAPTCHA_SECRET_KEY=your_recaptcha_secret_here

JWT_SECRET=change-me

TXN_API_BASE_URL=http://localhost:3003
TXN_PORT=3003

WHATSAPP_API_URL=http://192.168.60.62:3002/api/v1/
RABBITMQ_URL=http://192.168.60.62:15672/
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_AMQP_PORT=5672
NOTIFICATION_USE_QUEUE=false

EMAIL_ID=
EMAIL_PASS=

ENVIRONMENT1=DEVELOPMENT
DOCUMENT_VIEWER_IP=192.168.60.63:8080
alfresco_API_URL=http://192.168.60.63:8080/alfresco/api/-default-/public/alfresco/versions/1/nodes/
DEV_DOCUMENT_STORAGE_LOCATION=
PROD_DOCUMENT_STORAGE_LOCATION=
DMS_USER_ID=
DMS_PASSWORD=

AUDIT_TRACKED_USERS=
# AUDIT_TRACKED_USERS=user1,user2  # empty = track all logins

# FRONTEND_BUILD_PATH=C:/projects/Claims_project/claude-poc-fresh/life-claim-frontend/build

CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,https://192.168.60.62:3010,http://192.168.60.62:3010
